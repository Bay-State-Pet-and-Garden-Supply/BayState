{
  "name": "baystate-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Bay State Pet and Garden Supply - Next.js web app and Python scraper",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/web",
    "apps/scraper"
  ],
  "scripts": {
    "dev": "bunx turbo run dev",
    "build": "bunx turbo run build",
    "test": "bunx turbo run test",
    "lint": "bunx turbo run lint",
    "web": "bun --cwd apps/web",
    "scraper": "bun --cwd apps/scraper",
    "vercel-build": "cd apps/web && next build"
  },
  "dependencies": {
    "ansi-styles": "^4.3.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "turbo": "^2.8.17"
  }
}
