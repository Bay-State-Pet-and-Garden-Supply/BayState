# Node / build artifacts
/node_modules/
/.next/
/dist/
.env*
.DS_Store
logs/
tmp/
#XM|#.sisyphus/
.vscode/
*.log

# Workspace / stray files
test-coastal.js
# ignore everything in .opencode except `opencode.json`
.opencode/*
!.opencode/opencode.json
data/
nul

# Sisyphus QA Evidence - Ignore all evidence files except markers
.sisyphus/evidence/*
!.sisyphus/evidence/.gitkeep
!.sisyphus/evidence/README.md
pyrightconfig.json
.vercel

# ------------------------------
# Sensitive and credential files
# ------------------------------
# Explicitly ignore local env files (covers .env.local, .env.development.local, etc.)
.env.local
.env.*.local
.envrc

# npm, yarn credentials and configs
.npmrc
.yarnrc

# Docker credentials
.docker/config.json

# SSH key material
id_rsa
id_rsa.pub

# Certificate and key files
*.pem
*.key
*.crt

# note: keep other application JSON files tracked; avoid broad *.json ignores
