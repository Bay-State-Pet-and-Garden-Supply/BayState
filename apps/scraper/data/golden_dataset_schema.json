{
  "$defs": {
    "DatasetEntry": {
      "additionalProperties": true,
      "description": "A single golden dataset annotation.",
      "properties": {
        "query": {
          "minLength": 1,
          "title": "Query",
          "type": "string"
        },
        "expected_source_url": {
          "format": "uri",
          "minLength": 1,
          "title": "Expected Source Url",
          "type": "string"
        },
        "category": {
          "minLength": 1,
          "title": "Category",
          "type": "string"
        },
        "difficulty": {
          "enum": [
            "easy",
            "medium",
            "hard"
          ],
          "title": "Difficulty",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "sku": {
          "title": "SKU",
          "type": "string"
        },
        "product_name": {
          "title": "Product Name",
          "type": "string"
        },
        "brand": {
          "title": "Brand",
          "type": "string"
        }
      },
      "required": [
        "query",
        "expected_source_url",
        "category",
        "difficulty",
        "rationale"
      ],
      "title": "DatasetEntry",
      "type": "object"
    },
    "DatasetProvenance": {
      "additionalProperties": true,
      "description": "Metadata describing how the dataset was generated.",
      "properties": {
        "annotator": {
          "minLength": 1,
          "title": "Annotator",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "mode": {
          "title": "Mode",
          "type": "string"
        },
        "product_count": {
          "minimum": 0,
          "title": "Product Count",
          "type": "integer"
        },
        "workflow": {
          "title": "Workflow",
          "type": "string"
        }
      },
      "required": [
        "annotator",
        "source",
        "product_count"
      ],
      "title": "DatasetProvenance",
      "type": "object"
    }
  },
  "$id": "https://baystate.internal/schemas/golden_dataset_schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Validated golden dataset payload.",
  "properties": {
    "version": {
      "minLength": 1,
      "title": "Version",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/DatasetProvenance"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/DatasetEntry"
      },
      "title": "Entries",
      "type": "array"
    }
  },
  "required": [
    "version",
    "created_at",
    "provenance",
    "entries"
  ],
  "title": "GoldenDataset",
  "type": "object"
}
